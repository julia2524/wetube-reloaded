extends ../base

block content 
    span=errorMessage
    form(method="POST")
        input(placeholder="Old Password", type="password", name="oldPassword", required)
        input(placeholder="New Password", type="password", name="newPassword", required)
        input(placeholder="New Password Confirm", type="password",name="newPasswordConfirmation" required)
        input(type="submit", value="Change Password")